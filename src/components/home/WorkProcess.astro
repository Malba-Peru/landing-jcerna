---
import { workflow } from "../../data-list";
import Icon from "astro-icon";
---

<section class="process">
  <h1>Proceso de Trabajo</h1>

  <div class="grid">
    {workflow.map((step) => (
      <div class="card">
        <div class="icon-wrapper">
          <Icon name={step.icon} class="icon" />
        </div>

        <h2>{step.title}</h2>
        <p>{step.description}</p>
      </div>
    ))}
  </div>
</section>

<style lang="scss">
.process {
  padding: 3rem 1rem;
  max-width: 1200px;
  margin: auto;

  h1 {
    text-align: center;
    margin-bottom: 2rem;
    font-size: 2.2rem;
    color: #003f63;
    font-weight: 700;
  }

  .grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));

    .card {
      background-color: #015a8f;
      background-image:
        linear-gradient(
          90deg,
          rgba(255, 255, 255, 0.16) 2px,
          transparent 2px
        ),
        linear-gradient(
          rgba(255, 255, 255, 0.16) 2px,
          transparent 2px
        ),
        linear-gradient(
          90deg,
          transparent 30px,
          rgba(255, 255, 255, 0.14) 2px,
          transparent 32px
        );

      background-size: 60px 30px, 60px 30px, 60px 30px;
      background-position: 0 0, 0 0, 0 15px;

      color: white;
      padding: 2rem 1.5rem;
      border-radius: 14px;
      position: relative;
      text-align: center;
      box-shadow:
        inset 0 2px 4px rgba(255, 255, 255, 0.08),
        0 4px 12px rgba(0, 0, 0, 0.18);
      transition: transform 0.25s ease;

      &:hover {
        transform: translateY(-6px);
      }

      .icon-wrapper {
        width: 65px;
        height: 65px;
        margin: 0 auto 1rem;
        background: #003f63;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;

        .icon {
          width: 32px;
          height: 32px;
          color: white;
        }
      }

      h2 {
        font-size: 1.3rem;
        margin: 0.5rem 0 0.7rem;
        font-weight: 600;
      }

      p {
        font-size: 1rem;
        line-height: 1.4;
        text-align: justify;
        opacity: 0.92;
      }
    }
  }
}

@media (max-width: 480px) {
  .process {
    h1 {
      font-size: 1.8rem;
    }

    .grid {
      .card {
        padding: 1.5rem;
      }
    }
  }
}
</style>