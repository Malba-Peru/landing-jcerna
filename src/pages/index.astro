---
import { BaseLayout } from '../layouts';
import { AboutUs, Services, Carrousel, Path, WorkProcess } from "../components";
import Animations from "../components/ui/Animations.jsx";

interface Img {
  src: string;
  alt: string;
  title: string;
  subtitle: string;
}

const slides: Img[] = [
  {
    src: "/images/banner_1.webp",
    alt: "Construcción moderna",
    title: "CONSTRUIMOS CON EXCELENCIA",
    subtitle: "Calidad, innovación y compromiso en cada proyecto."
  },
  {
    src: "/images/banner_2.webp",
    alt: "Infraestructura sólida",
    title: "PROYECTOS QUE DEJAN HUELLA",
    subtitle: "Diseño, planificación y ejecución con altos estándares."
  },
  {
    src: "/images/banner_3.webp",
    alt: "Equipo profesional",
    title: "TU VISIÓN, NUESTRA MISIÓN",
    subtitle: "Creamos espacios funcionales, seguros y duraderos."
  },
];
---

<BaseLayout>
  <Animations client:idle />

  <main class="reveal">
    <Carrousel slides={slides} />
  </main>

  <div class="reveal">
    <Services />
  </div>

  <div class="reveal">
    <AboutUs />
  </div>

  <div class="reveal">
    <Path />
  </div>

  <div class="reveal">
    <WorkProcess />
  </div>
</BaseLayout>

<style lang="scss">
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.8s ease-out;
  }

  .reveal.show {
    opacity: 1;
    transform: translateY(0);
  }
</style>