---
import {BaseLayout} from '../layouts';
import {AboutUs, Services, Carrousel, Path} from "../components";
import Animations from "../components/ui/Animations.jsx";

interface Img { src: string; alt: string; }

const slides: Img[] = [
    { src: "/images/banner_1.webp", alt: "Banner" },
    { src: "/images/banner_2.webp", alt: "Banner" },
    { src: "/images/banner_3.webp", alt: "Banner" }
];
---

<BaseLayout>

  <Animations client:load />

  <main class="reveal">
      <Carrousel slides={slides} />
  </main>

  <section class="reveal">
    <Services />
  </section>

  <section class="reveal">
    <AboutUs />
  </section>

  <section class="reveal">
    <Path />
  </section>

</BaseLayout>

<style lang="scss">
  main {
    .banner-wrapper {
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      width: 100%;
      max-width: 1530px;
      min-height: 70vh;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        position: absolute;
        inset: 0;
        z-index: 100;
      }

      .wrapper-content {
        width: 90%;
        margin: auto;
        color: #fff;
        text-transform: uppercase;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 200;

        @media (min-width: 920px) {
          width: 60%;
        }

        .quote-wrapper {
          padding-top: 2em;

          a { text-decoration: auto; }
        }
      }
    }
  }

  @media (min-width: 920px) {
    main .banner-wrapper img {
      height: 70vh;
    }
  }
</style>
