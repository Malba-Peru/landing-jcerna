---
import BaseLayout from "../..//layouts/BaseLayout.astro";
import { galleryItems } from "../../data-list/gallery";
---

<BaseLayout>
  <section class="gallery">
    <h1>Galería</h1>

    <div class="cards-container">
      {galleryItems.map(item => (
        <a href={`/gallery/${item.slug}`} class="card">
          <div class="img-card">
            <img src={item.img} alt={item.title} class="card-image" />
            <h2>{item.title}</h2>
          </div>
          <div class="glow-separator"></div>
          <div class="text-card">
            <p>{item.desc}</p>
            <span>Ver más ►</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>



<style>
    .gallery {
        background: #243E57 ;
        padding: 2rem;

        h1 {
            text-align: center;
            color: white;
            margin-bottom: 2rem;
        }

        .cards-container {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            justify-items: center;
        }

        .card {
            background-color: #37474F ;
            border-radius: 12px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 400px;
            font-family: Arial, sans-serif;
            overflow: hidden;
            position: relative;
            color: inherit;
            text-decoration: none !important;
            transition: transform 0.3s ease;
        }

        .card:hover {
            transform: translateY(-5px);
        }

        .img-card {
            height: 250px;
            position: relative;

            &::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0, 0, 0, 0.5);
                z-index: 1;
            }

            .card-image {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.3s ease;
            }

            h2 {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                color: white;
                z-index: 2;
                margin: 0;
                font-size: 32px;
                font-weight: 700;
                text-align: center;
                width: 100%;
                padding: 0 20px;
            }
        }

        .glow-separator {
            width: 100%;
            height: 15px;
            position: relative;
            margin-top: -8px;
            z-index: 3;
            background: radial-gradient(circle at center, rgba(255, 255, 255, 0.4) 0%, transparent 70%);
            filter: blur(10px);
        }

        .text-card {
            padding: 24px;
            display: flex;
            flex-direction: column;
            gap: 16px;
            position: relative;

            p {
                margin: 0;
                color: #e2e8f0;
                font-size: 20px;
                line-height: 1.6;
                position: relative;
                padding-bottom: 12px;

                &::after {
                    content: '';
                    position: absolute;
                    bottom: 0;
                    left: 0;
                    width: 100%;
                    height: 2px;
                    background: linear-gradient(90deg, transparent 0%, #e2e8f0 50%, transparent 100%);
                }
            }

            span {
                color: #e2e8f0;
                font-weight: 500;
                font-size: 18px;
                text-decoration: none;
            }
        }

        @media (max-width: 1024px) {
            .cards-container {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 600px) {
            .cards-container {
                grid-template-columns: 1fr;
            }
        }
    }
</style>
